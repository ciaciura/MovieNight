@inject ILocalizationService LocalizationService
@using MovieNight.Web.Services

<div class="culture-selector">
    <label for="culture-select" class="form-label">Language</label>
    <select class="form-select" id="culture-select" @onchange="OnCultureChanged">
        @foreach (var culture in LocalizationService.SupportedCultures)
        {
            <option value="@culture.Name" selected="@(culture.Name == LocalizationService.CurrentCulture.Name)">
                @culture.DisplayName
            </option>
        }
    </select>
</div>

@code {
    private async Task OnCultureChanged(ChangeEventArgs e)
    {
        if (e.Value is string cultureName)
        {
            await LocalizationService.SetCultureAsync(cultureName);
        }
    }
}

<style>
.culture-selector {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.culture-selector .form-label {
    margin: 0;
    white-space: nowrap;
}

.culture-selector .form-select {
    min-width: 150px;
}
</style>
